    given-names: "Arnaldo"
license: MIT
repository-code: "https://github.com/Arnime/givp"
keywords:
  - optimization
  - metaheuristic
  - grasp
  - ils
  - vnd
  - path-relinking
  - global-optimization
version: 0.1.0
date-released: 2026-04-21
